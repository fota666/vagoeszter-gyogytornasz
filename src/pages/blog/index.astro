---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Blog - Vágó Eszter Gyógytornász" description="Hasznos cikkek a gyógytornáról, egészséges mozgásról és rehabilitációról.">
  <!-- Hero -->
  <section class="relative pt-32 pb-24 lg:pb-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950 via-navy-900 to-navy-800"></div>
    <svg class="absolute top-10 left-[10%] w-[300px] h-[300px] text-teal-400 opacity-[0.05]" viewBox="0 0 300 300" fill="none">
      <circle cx="150" cy="150" r="130" stroke="currentColor" stroke-width="0.75"/>
      <circle cx="150" cy="150" r="90" stroke="currentColor" stroke-width="0.5"/>
    </svg>
    <div class="absolute top-1/3 right-1/4 w-[250px] h-[250px] bg-teal-600/[0.06] rounded-full blur-[100px]"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="reveal inline-flex items-center gap-3 px-5 py-2.5 border border-gold-400/20 rounded-full mb-8">
        <div class="w-1.5 h-1.5 bg-gold-400 rounded-full animate-pulse"></div>
        <span class="text-gold-300/80 text-xs tracking-[0.15em] uppercase font-medium">Hasznos cikkek</span>
      </div>
      <h1 class="reveal stagger-1 font-heading text-4xl sm:text-5xl lg:text-[4.5rem] font-semibold text-white leading-[1.08]">Blog</h1>
      <p class="reveal stagger-2 mt-4 text-xl text-teal-200/50 max-w-xl mx-auto">
        Hasznos cikkek az egészséges mozgásról, rehabilitációról és prevencióról.
      </p>
    </div>
  </section>

  <section class="py-24 lg:py-32 bg-warm-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {allPosts.map((post, i) => (
          <div class={`reveal stagger-${(i % 3) + 1}`}>
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.id}
              image={post.data.image}
            />
          </div>
        ))}
      </div>

      {allPosts.length === 0 && (
        <p class="text-center text-navy-700/40 mt-12 text-lg">Hamarosan érkeznek az első bejegyzések!</p>
      )}
    </div>
  </section>
</BaseLayout>
