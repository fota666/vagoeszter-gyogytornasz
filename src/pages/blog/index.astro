---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="Blog - Vágó Eszter Gyógytornász" description="Hasznos cikkek a gyógytornáról, egészséges mozgásról és rehabilitációról.">
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-4xl sm:text-5xl font-bold text-sage-800 text-center">Blog</h1>
      <p class="mt-4 text-sage-500 text-center max-w-xl mx-auto">
        Hasznos cikkek az egészséges mozgásról, rehabilitációról és prevencióról.
      </p>

      <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {allPosts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id}
            image={post.data.image}
          />
        ))}
      </div>

      {allPosts.length === 0 && (
        <p class="text-center text-sage-400 mt-12">Hamarosan érkeznek az első bejegyzések!</p>
      )}
    </div>
  </section>
</BaseLayout>
