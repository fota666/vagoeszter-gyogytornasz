---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const formattedDate = post.data.date.toLocaleDateString('hu-HU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const base = import.meta.env.BASE_URL;
const clinicUrl = 'https://fota666.github.io/mckenzie-rendelo';
---

<BaseLayout title={`${post.data.title} - Vágó Eszter`} description={post.data.description}>
  <article class="pt-32 pb-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href={`${base}blog`} class="text-teal-600 hover:text-teal-700 text-sm font-medium transition-colors">&larr; Vissza a bloghoz</a>

      <h1 class="font-heading text-3xl sm:text-4xl font-semibold text-navy-900 mt-6">{post.data.title}</h1>
      <time class="block mt-3 text-sm text-navy-700/40">{formattedDate}</time>

      {post.data.image && (
        <img src={`${base}${post.data.image.replace(/^\//, '')}`} alt={post.data.title} class="w-full max-w-md mx-auto rounded-2xl mt-8 aspect-square object-cover border border-warm-200/50" />
      )}

      <div class="mt-8 prose max-w-none
        [&_h2]:font-heading [&_h2]:text-navy-900 [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:mt-10 [&_h2]:mb-4
        [&_h3]:font-heading [&_h3]:text-navy-900 [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-3
        [&_p]:text-navy-700/60 [&_p]:leading-relaxed [&_p]:mb-4
        [&_ul]:text-navy-700/60 [&_ul]:space-y-1 [&_ul]:mb-4 [&_ul]:list-disc [&_ul]:pl-5
        [&_ol]:text-navy-700/60 [&_ol]:space-y-1 [&_ol]:mb-4 [&_ol]:list-decimal [&_ol]:pl-5
        [&_li]:leading-relaxed
        [&_strong]:text-navy-800
        [&_a]:text-teal-600 [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-teal-700
        [&_hr]:border-warm-200 [&_hr]:my-8
        [&_blockquote]:border-l-2 [&_blockquote]:border-gold-400/40 [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-navy-700/50
      ">
        <Content />
      </div>

      <div class="mt-12 pt-8 border-t border-warm-200">
        <a href={`${clinicUrl}/kapcsolat#idopontfoglalas`} target="_blank" rel="noopener" class="inline-flex items-center bg-gold-500 hover:bg-gold-600 text-white px-6 py-3 rounded-full font-semibold transition-all hover:shadow-lg hover:shadow-gold-500/25 hover:-translate-y-0.5">
          Foglaljon időpontot
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
