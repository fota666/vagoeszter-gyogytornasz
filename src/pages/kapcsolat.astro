---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kapcsolat - Vágó Eszter Gyógytornász" description="Vegye fel a kapcsolatot Vágó Eszter gyógytornásszal.">
  <!-- Hero -->
  <section class="relative pt-32 pb-24 lg:pb-28 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950 via-navy-900 to-navy-800"></div>
    <svg class="absolute top-10 left-[5%] w-[300px] h-[300px] text-teal-400 opacity-[0.05]" viewBox="0 0 300 300" fill="none">
      <circle cx="150" cy="150" r="130" stroke="currentColor" stroke-width="0.75"/>
      <circle cx="150" cy="150" r="90" stroke="currentColor" stroke-width="0.5"/>
    </svg>
    <div class="absolute bottom-1/4 right-[10%] w-[200px] h-[200px] bg-gold-500/[0.04] rounded-full blur-[80px]"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="reveal inline-flex items-center gap-3 px-5 py-2.5 border border-gold-400/20 rounded-full mb-8">
        <div class="w-1.5 h-1.5 bg-gold-400 rounded-full animate-pulse"></div>
        <span class="text-gold-300/80 text-xs tracking-[0.15em] uppercase font-medium">Elérhetőségek</span>
      </div>
      <h1 class="reveal stagger-1 font-heading text-4xl sm:text-5xl lg:text-[4.5rem] font-semibold text-white leading-[1.08]">
        Kapcsolat
      </h1>
      <p class="reveal stagger-2 mt-4 text-xl text-teal-200/50 max-w-xl mx-auto">
        Keressen bizalommal telefonon vagy emailben!
      </p>
    </div>
  </section>

  <section class="py-24 lg:py-32 bg-warm-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="space-y-6">
          <div class="reveal stagger-1 bg-white rounded-2xl p-6 border border-warm-200/50 hover:shadow-lg hover:shadow-teal-600/[0.03] transition-all duration-500">
            <h2 class="font-heading text-xl font-semibold text-navy-900 mb-5">Elérhetőségek</h2>
            <div class="space-y-5">
              <a href="tel:+36304878284" class="flex items-center gap-4 group">
                <div class="w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center border border-teal-200/50">
                  <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-navy-700/40">Telefon</p>
                  <p class="text-navy-900 font-semibold group-hover:text-teal-600 transition-colors">(30) 487-8284</p>
                </div>
              </a>
              <a href="mailto:info@vagoeszter.hu" class="flex items-center gap-4 group">
                <div class="w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center border border-teal-200/50">
                  <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-navy-700/40">Email</p>
                  <p class="text-navy-900 font-semibold group-hover:text-teal-600 transition-colors">info@vagoeszter.hu</p>
                </div>
              </a>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center border border-teal-200/50">
                  <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-navy-700/40">Rendelő</p>
                  <p class="text-navy-900 font-semibold">1051 Budapest, Sas u. 7.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="reveal stagger-2 bg-white rounded-2xl p-6 border border-warm-200/50 hover:shadow-lg hover:shadow-teal-600/[0.03] transition-all duration-500">
            <h2 class="font-heading text-xl font-semibold text-navy-900 mb-3">Időpontfoglalás</h2>
            <p class="text-navy-700/45 text-sm mb-4">Foglaljon időpontot telefonon!</p>
            <a href="tel:+36304878284" class="inline-flex items-center bg-gold-500 hover:bg-gold-600 text-white px-6 py-3 rounded-full font-semibold transition-all hover:shadow-lg hover:shadow-gold-500/25 hover:-translate-y-0.5">
              (30) 487-8284
              <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>

        <div class="reveal stagger-3 rounded-2xl overflow-hidden shadow-lg border border-warm-200/50 min-h-[450px]">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3235!2d19.0505!3d47.5025!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4741dc43d tried!2sSas+u.+7%2C+Budapest%2C+1051!5e0!3m2!1shu!2shu"
            width="100%"
            height="100%"
            style="border:0; min-height:450px;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Rendelő helye"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
