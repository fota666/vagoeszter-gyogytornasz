---
const base = import.meta.env.BASE_URL;
---

<section class="py-24 lg:py-32 bg-white" id="kapcsolat">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="reveal text-gold-500 text-xs tracking-[0.2em] uppercase font-semibold">Elérhetőségek</span>
      <h2 class="reveal stagger-1 font-heading text-4xl sm:text-5xl font-semibold text-navy-900 mt-4">Kapcsolat</h2>
      <div class="w-10 h-[2px] bg-gradient-to-r from-gold-500 to-gold-300 mx-auto mt-5"></div>
      <p class="reveal stagger-2 mt-5 text-navy-700/50 text-lg">Keressen bizalommal telefonon vagy emailben!</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
      <a href="tel:+36304878284" class="reveal stagger-1 group bg-warm-50 rounded-2xl p-6 text-center border border-warm-200/60 hover:border-teal-300/50 hover:shadow-lg hover:shadow-teal-600/[0.04] transition-all duration-500">
        <div class="w-14 h-14 bg-teal-50 rounded-xl flex items-center justify-center mx-auto mb-4 border border-teal-200/50">
          <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </div>
        <h3 class="font-heading font-semibold text-navy-900 text-lg mb-1">Telefon</h3>
        <p class="text-teal-600 font-medium">(30) 487-8284</p>
      </a>
      <a href="mailto:info@vagoeszter.hu" class="reveal stagger-2 group bg-warm-50 rounded-2xl p-6 text-center border border-warm-200/60 hover:border-teal-300/50 hover:shadow-lg hover:shadow-teal-600/[0.04] transition-all duration-500">
        <div class="w-14 h-14 bg-teal-50 rounded-xl flex items-center justify-center mx-auto mb-4 border border-teal-200/50">
          <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="font-heading font-semibold text-navy-900 text-lg mb-1">Email</h3>
        <p class="text-teal-600 font-medium">info@vagoeszter.hu</p>
      </a>
      <a href={`${base}kapcsolat`} class="reveal stagger-3 group bg-warm-50 rounded-2xl p-6 text-center border border-warm-200/60 hover:border-gold-300/50 hover:shadow-lg hover:shadow-gold-500/[0.06] transition-all duration-500">
        <div class="w-14 h-14 bg-gold-100 rounded-xl flex items-center justify-center mx-auto mb-4 border border-gold-200/50">
          <svg class="w-6 h-6 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="font-heading font-semibold text-navy-900 text-lg mb-1">Időpontfoglalás</h3>
        <p class="text-gold-600 font-medium">Telefonon: (30) 487-8284</p>
      </a>
    </div>
    <div class="reveal rounded-2xl overflow-hidden shadow-lg h-72 border border-warm-200/60">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3235!2d19.0505!3d47.5025!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4741dc43d tried!2sSas+u.+7%2C+Budapest%2C+1051!5e0!3m2!1shu!2shu"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Rendelő helye"
      ></iframe>
    </div>
  </div>
</section>
