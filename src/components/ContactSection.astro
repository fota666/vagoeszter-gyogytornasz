---
const clinicUrl = 'https://mckenzie-rendelo.netlify.app';
---

<section class="py-24 bg-white" id="kapcsolat">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="reveal inline-block text-teal-600 font-semibold text-sm tracking-widest uppercase mb-3">Elérhetőségek</span>
      <h2 class="reveal font-heading text-4xl sm:text-5xl font-bold text-gray-900 stagger-1">Kapcsolat</h2>
      <p class="reveal mt-5 text-gray-500 text-lg stagger-2">Az időpontfoglalás a McKenzie Gyógytorna Rendelő központi rendszerén keresztül történik.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
      <a href="tel:+36304878284" class="reveal stagger-1 group bg-white rounded-2xl p-6 text-center border border-gray-100 hover:shadow-xl hover:shadow-gray-200/50 transition-all duration-500 hover:-translate-y-1">
        <div class="w-14 h-14 bg-teal-50 rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </div>
        <h3 class="font-semibold text-gray-900 mb-1">Telefon</h3>
        <p class="text-teal-600 font-medium">(30) 487-8284</p>
      </a>
      <a href="mailto:info@vagoeszter.hu" class="reveal stagger-2 group bg-white rounded-2xl p-6 text-center border border-gray-100 hover:shadow-xl hover:shadow-gray-200/50 transition-all duration-500 hover:-translate-y-1">
        <div class="w-14 h-14 bg-teal-50 rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="font-semibold text-gray-900 mb-1">Email</h3>
        <p class="text-teal-600 font-medium">info@vagoeszter.hu</p>
      </a>
      <a href={`${clinicUrl}/kapcsolat#idopontfoglalas`} target="_blank" rel="noopener" class="reveal stagger-3 group bg-white rounded-2xl p-6 text-center border border-gray-100 hover:shadow-xl hover:shadow-gray-200/50 transition-all duration-500 hover:-translate-y-1">
        <div class="w-14 h-14 bg-gold-100 rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="font-semibold text-gray-900 mb-1">Időpontfoglalás</h3>
        <p class="text-gold-600 font-medium">McKenzie Rendelő &rarr;</p>
      </a>
    </div>
    <div class="reveal rounded-2xl overflow-hidden shadow-lg h-72 border border-gray-100">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3235!2d19.0505!3d47.5025!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4741dc43d tried!2sSas+u.+7%2C+Budapest%2C+1051!5e0!3m2!1shu!2shu"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Rendelő helye"
      ></iframe>
    </div>
  </div>
</section>
