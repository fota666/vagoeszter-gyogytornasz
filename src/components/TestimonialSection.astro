---
const testimonials = [
  {
    text: 'Eszterrel élmény a gyógytorna is! Nagyon alapos és felkészült szakember. Mindig elmagyarázza a gyakorlatok hatását, és látszik, hogy a munkája a hivatása. Én először sport okozta derék-, majd bokasérüléssel kerestem fel. Mindkét esetben sokféle feladatot kaptam, a közös munka lényegretörő és következetes volt, így már néhány hónapon belül érezhető volt a javulás. És a legfontosabb, hogy torna közben a nevetés sem marad el! Csak ajánlani tudom!',
    name: 'Eszter Izsák',
  },
  {
    text: 'Eszterhez egy évtizedes gerincfájdalom miatt jártam. Nagy körültekintéssel segített megtalálni a forrásokat, és olyan gyakorlatokkal és tanácsokkal látott el, amiket a mai napig használok, és működnek. Szívből ajánlom!',
    name: 'Zsolt Kele',
  },
  {
    text: 'Deréktáji és vállpanaszokkal kerestem fel a rendelőt, ahol Eszter professzionális felkészültségének, valamint empatikus és segítőkész hozzáállásának köszönhetően rengeteg gyakorlatot tanultam, valamint sok összefüggést sikerült megértenem. A gyakorlatsor panaszaimhoz és képességeimhez igazodóan lett kialakítva, melyet Eszter a visszajelzéseim alapján minden további kezelés során aktualizált. Csak ajánlani tudom!',
    name: 'Péter Szabó',
  },
  {
    text: 'Hihetetlenül hálás vagyok, akik nagyon sokat segítettek eredeti problémámon. Eszter, a gyógytornászom mély tudással rendelkezik, nagyon profi. Ha kérem, mindent elmagyaráz a "miértről" a "hogyanig". Inspirál, támogat, buzdít. Nagyon jó érzés ilyen jó kezekben lenni!',
    name: 'Audrey',
  },
  {
    text: 'Eszti szuper szaktudással rendelkezik. Két hét alatt járóképessé varázsolt két kiszakadt porckorong sérvvel. Már három éve járok hozzá karbantartásra heti egy alkalommal. Összeállította az otthoni gyakorlataimat, figyelembe véve az állapotom változásait. Kedves, mókás, de szigorú gyógytornász. Csak ajánlani tudom!',
    name: 'Zoltán Balla',
  },
  {
    text: 'Vágó Eszternél volt a lányom. Alapos, jó szakember és nagyon kedves.',
    name: 'Katalin Füzesi',
  },
];
---

<section class="py-24 bg-cream">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="reveal inline-block text-teal-600 font-semibold text-sm tracking-widest uppercase mb-3">Vélemények</span>
      <h2 class="reveal font-heading text-4xl sm:text-5xl font-bold text-gray-900 stagger-1">Amit pácienseim mondanak</h2>
      <div class="reveal stagger-2 flex items-center justify-center gap-2 mt-4">
        <div class="flex text-gold-400">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
        </div>
        <span class="text-gray-500 font-medium">5.0 a Google-ön</span>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map((t, i) => (
        <div class={`reveal stagger-${(i % 6) + 1} bg-white rounded-2xl p-6 border border-gray-100 hover:shadow-xl hover:shadow-gray-200/50 transition-all duration-500 hover:-translate-y-1`}>
          <div class="flex text-gold-400 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-gray-600 leading-relaxed mb-5">{t.text}</p>
          <div class="flex items-center gap-3 pt-4 border-t border-gray-100">
            <div class="w-10 h-10 rounded-full bg-teal-50 flex items-center justify-center text-teal-600 font-bold text-sm">
              {t.name.charAt(0)}
            </div>
            <span class="font-medium text-gray-900">{t.name}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
