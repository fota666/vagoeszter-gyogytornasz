<section class="py-24 lg:py-32 bg-warm-100">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-[2rem] shadow-lg shadow-navy-900/[0.04] border border-warm-200/50 overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-5">
        <!-- PDF visual -->
        <div class="md:col-span-2 bg-navy-800 p-8 flex flex-col items-center justify-center text-center relative overflow-hidden">
          <svg class="absolute -right-6 -top-6 w-[200px] h-[200px] text-teal-400 opacity-[0.07]" viewBox="0 0 200 200" fill="none">
            <circle cx="100" cy="100" r="85" stroke="currentColor" stroke-width="0.75"/>
            <circle cx="100" cy="100" r="55" stroke="currentColor" stroke-width="0.5"/>
          </svg>
          <div class="relative">
            <div class="w-24 h-32 bg-white/[0.07] backdrop-blur-sm rounded-lg mx-auto mb-4 flex flex-col items-center justify-center border border-white/[0.07]">
              <svg class="w-10 h-10 text-white/70 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <span class="text-white/60 text-xs font-bold">PDF</span>
            </div>
            <h3 class="text-white font-heading text-xl font-semibold leading-tight">Reggeli torna<br/>gyakorlatok</h3>
            <p class="text-teal-200/40 text-sm mt-2">Ingyenes útmutató</p>
          </div>
        </div>

        <!-- Form -->
        <div class="md:col-span-3 p-8 sm:p-10">
          <div class="inline-flex items-center gap-2 bg-gold-100 text-gold-600 text-xs font-bold px-3 py-1 rounded-full mb-4 uppercase tracking-wider">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1zm7-10a1 1 0 01.967.744L14.146 7.2 17.5 7.512a1 1 0 01.576 1.775l-2.47 1.98.752 3.14a1 1 0 01-1.504 1.093L12 13.705 9.146 15.5a1 1 0 01-1.504-1.093l.752-3.14-2.47-1.98a1 1 0 01.576-1.775l3.354-.312 1.179-3.446A1 1 0 0112 2z"/></svg>
            Ingyenes
          </div>
          <h2 class="font-heading text-2xl sm:text-3xl font-semibold text-navy-900">
            5 perces reggeli torna — <span class="text-teal-600">PDF útmutató</span>
          </h2>
          <p class="mt-3 text-navy-700/50 leading-relaxed">
            Add meg az email címed, és azonnal küldöm az ingyenes gyakorlatsort, amivel energikusan indíthatod a napod. Képes útmutató, otthon is könnyen végezhető.
          </p>
          <ul class="mt-4 space-y-2">
            <li class="flex items-center gap-2 text-sm text-navy-700/55">
              <svg class="w-5 h-5 text-teal-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              5 perces, bárki számára végezhető gyakorlatsor
            </li>
            <li class="flex items-center gap-2 text-sm text-navy-700/55">
              <svg class="w-5 h-5 text-teal-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Képes útmutató lépésről lépésre
            </li>
            <li class="flex items-center gap-2 text-sm text-navy-700/55">
              <svg class="w-5 h-5 text-teal-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              McKenzie-alapú, evidencia-alapú gyakorlatok
            </li>
          </ul>

          <form
            name="lead-magnet"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="mt-6"
            id="lead-form"
          >
            <input type="hidden" name="form-name" value="lead-magnet" />
            <p class="hidden"><label>Ne töltsd ki: <input name="bot-field" /></label></p>
            <div class="flex flex-col sm:flex-row gap-3">
              <input
                type="email"
                name="email"
                required
                placeholder="Az email címed"
                class="flex-1 px-5 py-3.5 rounded-xl border border-warm-200 focus:border-teal-400 focus:ring-2 focus:ring-teal-100 outline-none transition-all text-navy-900 placeholder:text-navy-700/30"
              />
              <button
                type="submit"
                class="bg-gold-500 hover:bg-gold-600 text-white px-7 py-3.5 rounded-xl font-semibold transition-all hover:shadow-lg hover:shadow-gold-500/25 hover:-translate-y-0.5 shrink-0 flex items-center gap-2"
              >
                Küldés
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
              </button>
            </div>
            <p class="mt-3 text-xs text-navy-700/30">Nem küldök spam-et. Bármikor leiratkozhatsz.</p>
          </form>

          <!-- Success message -->
          <div id="form-success" class="hidden mt-6 bg-teal-50 border border-teal-200/50 rounded-xl p-5 text-center">
            <svg class="w-10 h-10 text-teal-500 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <h4 class="font-heading text-lg font-semibold text-teal-800">Köszönöm a feliratkozást!</h4>
            <p class="text-teal-600 text-sm mt-1">A PDF-et hamarosan megkapod emailben.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    try {
      await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(formData as any).toString(),
      });
      form.classList.add('hidden');
      success?.classList.remove('hidden');
    } catch {
      form.submit();
    }
  });
</script>
