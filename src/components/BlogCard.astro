---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  image?: string;
}

const { title, description, date, slug, image } = Astro.props;
const formattedDate = date.toLocaleDateString('hu-HU', { year: 'numeric', month: 'long', day: 'numeric' });
---

<a href={`/blog/${slug}`} class="group block bg-white rounded-2xl overflow-hidden border border-gray-100 hover:shadow-xl hover:shadow-gray-200/50 transition-all duration-500 hover:-translate-y-1">
  <div class="aspect-square bg-teal-50 overflow-hidden relative">
    {image ? (
      <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <div class="w-16 h-16 rounded-xl bg-white flex items-center justify-center">
          <svg class="w-8 h-8 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
        </div>
      </div>
    )}
  </div>
  <div class="p-6">
    <time class="text-xs font-medium text-teal-600 bg-teal-50 px-2 py-1 rounded-full">{formattedDate}</time>
    <h3 class="font-heading text-xl font-semibold text-gray-900 mt-3 group-hover:text-teal-700 transition-colors duration-300">{title}</h3>
    <p class="text-gray-500 mt-2 line-clamp-2 leading-relaxed">{description}</p>
    <span class="inline-flex items-center gap-1 mt-4 text-teal-600 font-medium text-sm group-hover:gap-2 transition-all duration-300">
      Olvasd tovább
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </span>
  </div>
</a>
