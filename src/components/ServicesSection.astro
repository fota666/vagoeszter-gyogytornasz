---
const services = [
  {
    title: 'McKenzie-féle kivizsgálás',
    description: 'Részletes mechanikai vizsgálat, amely feltárja a panaszaid okát és megmutatja, milyen irányú mozgás segít rajtad.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />`,
    image: '/images/gyogytorna_4.png',
  },
  {
    title: 'Önkezelés tanítás',
    description: 'Megtanítom azokat a gyakorlatokat, amelyekkel otthon, önállóan kezelheted a panaszaidat — hogy ne függj senkitől.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />`,
    image: '/images/gyogytorna_3.png',
  },
  {
    title: 'Derék- és nyakpanaszok',
    description: 'A McKenzie-módszer különösen hatékony a gerinc eredetű fájdalmak — derékfájás, nyakfájás, kisugárzó fájdalom — kezelésében.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`,
    image: '/images/gyogytorna_1.png',
  },
  {
    title: 'Megelőzés és karbantartás',
    description: 'Akinek már volt panasza, annak megtanítom, hogyan előzze meg a visszatérést — hogy hosszú távon fájdalommentesen éljen.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />`,
    image: '/images/gyogytorna_2.png',
  },
];
---

<section class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-xl mb-16 lg:mb-20">
      <span class="reveal text-gold-500 text-xs tracking-[0.2em] uppercase font-semibold">Hogyan segítek</span>
      <h2 class="reveal stagger-1 font-heading text-4xl sm:text-5xl font-semibold text-navy-900 mt-4 leading-tight">
        A McKenzie-módszer lényege
      </h2>
      <div class="w-10 h-[2px] bg-gradient-to-r from-gold-500 to-gold-300 mt-5"></div>
      <p class="reveal stagger-2 mt-5 text-navy-700/50 text-lg leading-relaxed">
        Nem kezellek hagyományos értelemben — megtanítalak rá, hogyan kezeld magad. Kevesebb alkalom, tartósabb eredmény.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {services.map((service, i) => (
        <div class={`reveal stagger-${i + 1} group bg-warm-50 rounded-2xl overflow-hidden border border-warm-200/60 hover:border-teal-300/50 hover:shadow-lg hover:shadow-teal-600/[0.04] transition-all duration-500 flex flex-row`}>
          {service.image && (
            <div class="w-36 sm:w-44 shrink-0 aspect-square overflow-hidden">
              <img src={service.image} alt={service.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
            </div>
          )}
          <div class="p-6">
            <div class="w-10 h-10 bg-teal-50 rounded-xl flex items-center justify-center mb-3 border border-teal-200/50">
              <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={service.icon} />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-semibold text-navy-900 group-hover:text-teal-700 transition-colors duration-300">{service.title}</h3>
            <p class="mt-2 text-navy-700/50 leading-relaxed text-sm">{service.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
